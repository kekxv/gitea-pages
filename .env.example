# Gitea Pages Configuration

# Domain for pages hosting (e.g., example.com)
# Users access sites at: https://username.<DOMAIN>/
DOMAIN=yourdomain.com

# Webhook secret - must match Gitea webhook secret
WEBHOOK_SECRET=your-secret-key

# Webhook listener port
WEBHOOK_PORT=8080

# HTTP port (nginx)
HTTP_PORT=80

# HTTPS port (nginx)
HTTPS_PORT=443

# Enable HTTPS with Let's Encrypt
ENABLE_HTTPS=false

# Email for Let's Encrypt certificate registration
CERT_EMAIL=admin@yourdomain.com

# Pages data directory on host
PAGES_DATA_DIR=/data/gitea-pages

# Maximum size per site in MB (default: 100MB)
MAX_SITE_SIZE_MB=100

# UID/GID for non-privileged user in containers
PUID=1000
PGID=1000

# =============================================================================
# Gitea Connection Configuration
# =============================================================================

# Gitea API URL (internal network, for API calls)
GITEA_API_URL=http://gitea:3000

# Optional: Gitea Access Token (legacy mode, shared token)
# If not set, use OAuth2 for user self-authorization
# Create at: Gitea -> Settings -> Applications -> Access Tokens
# Required scopes: write:repository, write:admin, write:user
GITEA_ACCESS_TOKEN=

# Optional: SSH key for private repos
# Place your SSH key in /data/gitea-pages/.ssh/id_rsa
# GITEA_SSH_KEY_PATH=/var/www/pages/.ssh/id_rsa

# =============================================================================
# OAuth2 Configuration (Recommended)
# =============================================================================
# Users can self-authorize for automatic webhook registration
# and private repository access.

# Create OAuth2 Application in Gitea:
#   1. Go to Settings -> Applications -> OAuth2 Applications
#   2. Click "Create OAuth2 Application"
#   3. Fill in:
#      - Application Name: Gitea Pages
#      - Redirect URIs: Add all domains you will use, e.g.:
#          http://localhost:8080/oauth/callback
#          https://pages.yourdomain.com/oauth/callback
#      - Confidential Client: YES (Important!)
#   4. Copy Client ID and Client Secret below

OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# Default redirect URL (used when Host header is not available)
OAUTH_REDIRECT_URL=http://localhost:8080/oauth/callback

# Webhook URL (internal Docker network, for Gitea to call)
WEBHOOK_PUBLIC_URL=http://deployer:8080/webhook

# Gitea Public URL (for user browser to access)
GITEA_PUBLIC_URL=http://localhost:3000