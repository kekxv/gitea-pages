# Gitea Pages Quickstart Configuration

DOMAIN=pages.local
WEBHOOK_SECRET=test-webhook-secret
MAX_SITE_SIZE_MB=50

# Gitea API URL (internal Docker network)
GITEA_API_URL=http://gitea:3000

# Gitea Access Token (optional, for legacy webhook registration)
# If not set, use OAuth2 for user self-authorization
GITEA_ACCESS_TOKEN=

# OAuth2 Configuration (for user self-authorization)
# Create OAuth2 app in Gitea: Settings -> Applications -> OAuth2 Applications
# Click "Create OAuth2 Application" and fill in:
#   - Application Name: Gitea Pages
#   - Redirect URI: Add ALL domains you will use:
#       http://localhost:8080/oauth/callback
#       http://pages.local:8888/oauth/callback
#       https://your-domain.com/oauth/callback
#   - Confidential Client: YES (IMPORTANT!)
#
# After creation, copy Client ID and Client Secret below:
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URL=http://localhost:8080/oauth/callback

# Webhook URL (internal Docker network, for Gitea to call)
WEBHOOK_PUBLIC_URL=http://deployer:8080/webhook

# Gitea Public URL (for user browser to access)
GITEA_PUBLIC_URL=http://localhost:3000